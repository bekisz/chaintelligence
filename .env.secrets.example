# ==============================================================================
# SECRETS TEMPLATE (Copy to .env.secrets)
# ==============================================================================
# This is a template for sensitive data. 
# NEVER commit your actual .env.secrets file to Git.
#
# INSTRUCTIONS:
# 1. Copy this file to .env.secrets: `cp .env.secrets.example .env.secrets`
# 2. Fill in the values below.
# 3. Non-sensitive settings are managed in .env.config.

# --- Infrastructure & Database ---

# DATA_WAREHOUSE_DB: Connection string for the internal Postgres database.
DATA_WAREHOUSE_DB=dbname=chaintelligence user=airflow password=airflow host=postgres port=5432

# --- Airflow Core Infrastructure ---
# Generate these locally using: `openssl rand -base64 32`
# These are used for encrypting connections and securing the internal API.
AIRFLOW__CORE__INTERNAL_API_SECRET_KEY=yours_here
AIRFLOW__CORE__FERNET_KEY=yours_here
AIRFLOW__WEBSERVER__SECRET_KEY=yours_here
AIRFLOW__API_AUTH__JWT_SECRET=yours_here

# --- External API Keys ---

# The Graph: Get your API Key at https://thegraph.com/studio/
# Used for fetching Uniswap V3 swap events and V4 history.
GRAPH_API_KEY=yours_here

# CoinMarketCap: Get your API Key at https://coinmarketcap.com/api/
# Used for primary price feeds and coin metadata matching.
CMC_API_KEY=yours_here


# --- Blockchain Connectivity ---

# Ethereum RPC Provider: Use Ankr (https://www.ankr.com/), Alchemy, or Infura.
# This is crucial for verifying claims and scanning for on-chain events.
RPC_URL=https://rpc.ankr.com/eth/your_node_id
RPC_URL_ETHEREUM=

# --- Application Access ---

# Portal credentials for the web dashboard.
## API Layer
PORTAL_USERNAME=admin
PORTAL_PASSWORD=chaintelligence_portal_password

# --- Monitoring Targets ---

# TARGET_ADDRESS: Target wallet addresses to track for LP positions (comma separated).
TARGET_ADDRESS=0x123...,0x456...