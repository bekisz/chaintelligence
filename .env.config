# ==============================================================================
# APPLICATION CONFIGURATION (Public / Non-Sensitive)
# ==============================================================================
# This file contains non-secret settings that define app behavior.
# It CAN be committed to the repository.

# ==============================================================================
# DAG: coin_price_update_cmc
# ==============================================================================

# --- TIER 1 (Critical: Live Positions) ---
# Tier 1 updates coins found in active LP positions.
# This tier runs on every DAG execution (default: ~15 mins).
# Resulting symbols are merged from DB (active pools) + this force-include list.
CMC_TIER1_FORCE_INCLUDE_COIN_LIST=BTC,ETH,SOL,UNI,AAVE,DAI,PENDLE,LINK,STETH

# --- TIER 2 (High Priority: Top Market Caps) ---
# TIER2_MAX_RANK: The rank threshold for this tier (e.g., 200 = coins ranked 1-200).
CMC_TIER2_MAX_RANK=200
# TIER2_INTERVAL_MINUTES: Only fetch if the last update was more than X minutes ago.
CMC_TIER2_INTERVAL_MINUTES=60
# TIER2_FORCE_INCLUDE_COIN_LIST: Comma-separated symbols to always fetch in this tier.
CMC_TIER2_FORCE_INCLUDE_COIN_LIST=

# --- TIER 3 (Standard Priority: Mid/Small Caps) ---
# TIER3_MAX_RANK: The rank limit. Use -1 to fetch ALL remaining coins after Tier 2.
CMC_TIER3_MAX_RANK=2000
# TIER3_INTERVAL_MINUTES: Frequency for mid-cap updates (usually longer than Tier 2).
CMC_TIER3_INTERVAL_MINUTES=300
# TIER3_FORCE_INCLUDE_COIN_LIST: Comma-separated symbols to always fetch in this tier.
CMC_TIER3_FORCE_INCLUDE_COIN_LIST=


# ==============================================================================
# DAG: backfill_claims / ingestion
# ==============================================================================

# SKIP_CLAIM_NETWORKS: Comma-separated list of networks to exclude from claim scanning.
SKIP_CLAIM_NETWORKS=Arbitrum

# CLAIM_SCAN_DEPTH: Number of blocks to look back for claim events in the RPC scanner.
CLAIM_SCAN_DEPTH=2000000


RPC_DISCOVERY_START_DATE=2025-11-01